---
import { niches, type Niche } from '~/data/niches';

interface Props {
  niche?: Niche;
}

const { niche } = Astro.props;

// home page defaults — what you see when no niche is set
const home = {
  name: 'home services',
  fullName: 'home service operators',
  hero: {
    lossAmount: '$40,000',
    badgeText: 'Now booking 50 home-service operators in the US',
    subExample: "on the roof, in a crawlspace, or asleep",
  },
  pain: { avgJobValue: '$487' },
  terminal: {
    companyName: 'home-service-co',
    callTime: '02:47:11.302',
    callerNumber: '+1-602-555-0193',
    emergencyQuote: '"...water heater leaking everywhere..."',
    classifyTags: 'emergency · water_heater · phoenix',
    pricingLookup: 'pricing.water_heater_emergency',
    techName: 'jose',
    composeQuote: '"I can have Jose at your place by 4 AM..."',
    bookSlot: '04:00',
    jobPrice: '$389',
    jobId: '4029',
    pipelineLine: '12 calls answered · 4 jobs booked · $3,840 in pipeline (today)',
  },
};

const data = niche ?? home;
const isHome = !niche;

// pick 3 testimonials: current niche/HVAC first, then two others for variety
const primaryTestimonial = niche
  ? { ...niche.testimonial, name: niche.name }
  : { ...niches.find((n) => n.slug === 'hvac')!.testimonial, name: 'HVAC' };

const otherNiches = niches
  .filter((n) => n.slug !== (niche?.slug ?? 'hvac'))
  .filter((n) => (niche ? true : n.slug !== 'hvac'))
  .slice(0, 2);

const testimonials = [
  primaryTestimonial,
  ...otherNiches.map((n) => ({ ...n.testimonial, name: n.name })),
];

// for the demo section header — adapt to niche
const demoTitle = niche
  ? `Watch your AI book a ${niche.name.toLowerCase()} job at 2:47 AM.`
  : 'Watch your AI book a job at 2:47 AM.';

// founder name (placeholder until real founder named)
const founderName = 'Marcus Webb';
const founderInitials = 'MW';

// dynamic trace lines for the demo card — niche-specific
const traceLines = [
  { t: data.terminal.callTime, e: 'call.in', d: data.terminal.callerNumber },
  { t: data.terminal.callTime, e: 'transcribe', d: data.terminal.emergencyQuote },
  { t: data.terminal.callTime, e: 'classify', d: data.terminal.classifyTags },
  { t: data.terminal.callTime, e: 'lookup', d: data.terminal.pricingLookup },
  { t: data.terminal.callTime, e: 'tool.call', d: `check_calendar(tech=${data.terminal.techName}, today)` },
  { t: data.terminal.callTime, e: 'compose', d: data.terminal.composeQuote },
  { t: data.terminal.callTime, e: 'tool.call', d: `book_job(slot=${data.terminal.bookSlot}, tech=${data.terminal.techName}, ${data.terminal.jobPrice})` },
  { t: data.terminal.callTime, e: 'sms.send', d: `confirmation_sent · job_id=${data.terminal.jobId}` },
];
