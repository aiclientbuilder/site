  </div>
</section>

<script is:inline define:vars={{ companyName: data.terminal.companyName, traceLines, pipelineLine: data.terminal.pipelineLine }}>
  (function() {
    var lines = [
      { p: '$', c: 'acb init ' + companyName, d: 0 },
      { t: '✓ Connected to your phone line, GHL, calendar (3.2s)', d: 800 },
      { t: '✓ Imported 1,847 past customers · 14 service types detected', d: 1500 },
      { p: '$', c: 'acb deploy --agent=24-7-receptionist', d: 2400 },
      { t: '⠼ Training agent on your service area & pricing...', d: 3000 },
      { t: '✓ Live. First call answered in 3.1s', d: 4200 },
      { p: '$', c: 'acb status', d: 5200 },
      { hi: pipelineLine, d: 6000 }
    ];
    var body = document.getElementById('terminal-body');
    if (!body) return;
    function start() {
      lines.forEach(function(l, i) {
        setTimeout(function() {
          var div = document.createElement('div');
          div.className = 'term-line';
          if (l.p) div.innerHTML = '<span class="prompt">' + l.p + '</span> <span class="cmd">' + l.c + '</span>';
          else if (l.hi) div.innerHTML = '<span class="hi">→ ' + l.hi + '</span>';
          else div.innerHTML = '<span class="out">' + l.t + '</span>';
          body.appendChild(div);
          if (i === lines.length - 1) {
            setTimeout(function() { var c = document.createElement('span'); c.className = 'term-cursor'; body.appendChild(c); }, 500);
          }
        }, l.d);
      });
    }
    var obs = new IntersectionObserver(function(entries) { if (entries[0].isIntersecting) { start(); obs.disconnect(); } });
    obs.observe(body);
  })();

  (function() {
    var list = document.getElementById('trace-list');
    if (!list) return;
    traceLines.forEach(function(l) {
      var row = document.createElement('div');
      row.className = 'trace-row';
      row.innerHTML = '<span class="trace-t">' + l.t + '</span><span class="trace-e">' + l.e + '</span><span>' + l.d + '</span>';
      list.appendChild(row);
    });
  })();

  document.getElementById('faq-list').addEventListener('click', function(e) {
    var btn = e.target.closest('.faq-q');
    if (!btn) return;
    var item = btn.parentElement;
    var wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(function(x) { x.classList.remove('open'); });
    if (!wasOpen) item.classList.add('open');
  });
</script>
